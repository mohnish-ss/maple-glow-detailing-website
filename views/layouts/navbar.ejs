<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/images/webicon.png" />
  
  <!-- This style is used to ensure that the CSS loads before the HTML, preventing FOUC (Flash of Unstyled Content). -->
  <style>
    html {
      visibility: hidden;
      opacity: 0;
    }
  </style>

  <link rel="stylesheet" href="/styles.css">
</head>
<% const activePath = typeof currentPath !== "undefined" ? currentPath : ""; %>
<div class="fade-in-container-a">
  <nav class="navbar">
    <button class="hamburger-menu" type="button" aria-label="Open navigation" aria-expanded="false">
      <div class="hamburger-line"></div>
      <div class="hamburger-line"></div>
      <div class="hamburger-line"></div>
    </button>

    <div class="nav-left">
      <a class="navbar-element <%= activePath === '/' || activePath === '/home' ? 'active' : '' %>" href="/home">Home</a>
      <a class="navbar-element <%= activePath === '/booking' ? 'active' : '' %>" href="/booking">Book</a>
      <a class="navbar-element <%= activePath === '/estimate' ? 'active' : '' %>" href="/estimate">Estimate</a>
      <a class="navbar-element <%= activePath === '/contact' ? 'active' : '' %>" href="/contact">Contact</a>
    </div>

    <div class="nav-center">
      <a href="/home"><img src="/images/mapleglowlogo.png" alt="Maple Glow Logo" /></a>
    </div>

    <!-- If the user is logged-in, shows the "Log-out" and "Profile" buttons instead of the "Sign-up" and "Log-in" buttons -->
    <% if (isLoggedIn) { %>
      <div class="nav-right">
        <a class="navbar-element" href="/logout">Log out</a>
        <a class="important-navbar-element <%= activePath === '/profile' ? 'active' : '' %>" href="/profile">Profile</a>
      </div>
    <% } else { %>
      <div class="nav-right">
        <a class="navbar-element <%= activePath === '/sign-up' ? 'active' : '' %>" href="/sign-up">Sign up</a>
        <a class="important-navbar-element <%= activePath === '/login' ? 'active' : '' %>" href="/login">Log in</a>
      </div>
    <% } %>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const hamburger = document.querySelector('.hamburger-menu');
    const navLinks = document.querySelector('.nav-right');
    const navLeft = document.querySelector('.nav-left');

    if (hamburger) {
      hamburger.addEventListener('click', function () {
        hamburger.classList.toggle('active');
        hamburger.setAttribute('aria-expanded', hamburger.classList.contains('active') ? 'true' : 'false');
        // Toggle mobile menu
        document.querySelector('.navbar').classList.toggle('menu-open');
      });
    }
  });
</script>
