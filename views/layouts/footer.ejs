<div class="footer-divider" style="height: 1px; background-color: var(--border-light); margin: 0 auto; max-width: 1400px;"></div>
<footer class="footer-container" style="background-color: var(--bg); padding: 1.5rem var(--page-gutter) 1.25rem; color: var(--text-secondary);">
    <div style="max-width: 1400px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem; margin-bottom: 1.25rem;">
        
        <!-- Column 1: Brand -->
        <div style="display: flex; align-items: center; gap: 12px;">
