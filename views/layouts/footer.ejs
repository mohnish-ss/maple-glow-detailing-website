            <a href="/booking" style="color: var(--text-secondary); text-decoration: none; transition: color var(--transition);">Book a Detail</a>
            <a href="/estimate" style="color: var(--text-secondary); text-decoration: none; transition: color var(--transition);">AI Cost Estimator</a>
            <a href="/contact" style="color: var(--text-secondary); text-decoration: none; transition: color var(--transition);">Contact Us</a>
        </div>

        <!-- Column 3: Contact Info -->
        <div style="display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; font-size: 0.85rem;">
            <div style="display: flex; align-items: center; gap: 6px;">
