<!DOCTYPE html>

<head>
    <%- include('layouts/navbar'); -%>
        <title>Forgot Password</title>
</head>

<body>

    <div style="margin-top: 4vh;" class="fade-in-container">
        <h1 class="login-title">Forgot your password?</h1>

        <h2 class="login-subtitle">Recover your account below.</h2>

    </div>

    <div class="forgot-password-container fade-in-container">

        <div class="forgot-password-card">
            <div class="forgot-step" id="step1">
                <label class="forgot-step-label">Step 1 — Enter your email</label>
                <input class="input-box" id="customerEmail" placeholder="E-mail" autocomplete="email">
                <span id="emailVerification" class="email-verification"></span>
                <button id="sendEmailButton" class="forgot-submit-button" onclick="sendEmail()">Send verification code</button>
            </div>

            <div class="forgot-step" id="step2">
                <label class="forgot-step-label">Step 2 — Enter your code</label>
                <input class="input-box" id="code" placeholder="6-digit verification code" disabled maxlength="6">
                <span id="codeVerificationLabel" class="code-verification"></span>
                <button id="verifyCodeButton" class="forgot-submit-button-disabled" onclick="verifyCode()" disabled>Verify code</button>
            </div>
        </div>

    </div>

</body>
<script>
    let code = document.getElementById("code");
    code.style.backgroundColor = '#e7e7e7';
    const customerEmail = document.getElementById('customerEmail');
    const csrfToken = '<%= csrfToken %>';
    
    // Guard flag to prevent duplicate API calls
    let emailSending = false;
    let codeVerifying = false;

    let cooldownTimer = null;
    
    //Function that sends the user an e-mail containing the verification code to login.
    async function sendEmail() {
        if (emailSending) return;
        
        let email = document.getElementById('customerEmail').value;
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const verifyCodeButton = document.getElementById("verifyCodeButton");
        const sendEmailButton = document.getElementById("sendEmailButton");

        if (!emailRegex.test(email)) {
            emailVerification.innerHTML = "Invalid e-mail address";
            emailVerification.style.color = "red";
            emailVerification.style.opacity = 1;
            return;
        }
        
        emailSending = true;
        sendEmailButton.disabled = true;
        sendEmailButton.classList.add("forgot-submit-button-disabled");
        sendEmailButton.classList.remove("forgot-submit-button");
        sendEmailButton.textContent = "Sending...";
        
        try {
            const response = await fetch('forgot-password-email', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email, _csrf: csrfToken }),
            });
            const result = await response.text();
            
            // Enable step 2
            verifyCodeButton.removeAttribute("disabled");
            verifyCodeButton.classList.add("forgot-submit-button");
            verifyCodeButton.classList.remove("forgot-submit-button-disabled");
            code.style.backgroundColor = 'white';
            code.removeAttribute("disabled");
            code.focus();
            customerEmail.style.backgroundColor = '#e7e7e7';
            customerEmail.setAttribute("disabled", true);
            
            emailVerification.innerHTML = result;
            emailVerification.style.color = "rgb(26, 155, 26)";
            emailVerification.style.opacity = 1;
            
            document.getElementById("step2").classList.add("active");

            // Cooldown logic
            let timeLeft = 60;
            sendEmailButton.textContent = `Resend in ${timeLeft}s`;
            
            cooldownTimer = setInterval(() => {
                timeLeft--;
                if (timeLeft <= 0) {
                    clearInterval(cooldownTimer);
                    emailSending = false;
                    sendEmailButton.disabled = false;
                    sendEmailButton.classList.remove("forgot-submit-button-disabled");
                    sendEmailButton.classList.add("forgot-submit-button");
                    sendEmailButton.textContent = "Resend code";
                    customerEmail.style.backgroundColor = 'white';
                    customerEmail.removeAttribute("disabled");
                } else {
                    sendEmailButton.textContent = `Resend in ${timeLeft}s`;
                }
            }, 1000);

        } catch (error) {
            emailSending = false;
            sendEmailButton.disabled = false;
            sendEmailButton.classList.remove("forgot-submit-button-disabled");
            sendEmailButton.classList.add("forgot-submit-button");
            sendEmailButton.textContent = "Send verification code";
            emailVerification.innerHTML = "Something went wrong. Try again.";
            emailVerification.style.color = "red";
            emailVerification.style.opacity = 1;
        }
    }

    //Verifies the code by using a POST method contained in the index.js file.
    async function verifyCode() {
        if (codeVerifying) return;

        const codeValue = document.getElementById("code").value;
        const codeVerificationLabel = document.getElementById("codeVerificationLabel");
        const verifyCodeButton = document.getElementById("verifyCodeButton");
        
        if (!codeValue || codeValue.length < 6) {
            codeVerificationLabel.innerHTML = "Please enter the 6-digit code";
            codeVerificationLabel.style.color = "red";
            codeVerificationLabel.style.opacity = 1;
            return;
        }

        codeVerifying = true;
        verifyCodeButton.disabled = true;
        verifyCodeButton.textContent = "Verifying...";

        try {
            const response = await fetch('verify-code', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ codeValue, _csrf: csrfToken }),
            });

            const result = await response.text();

            if (result == "Code verified successfully") {
                codeVerificationLabel.innerHTML = "✓ " + result;
                codeVerificationLabel.style.color = "rgb(26, 155, 26)";
                codeVerificationLabel.style.opacity = 1;
                verifyCodeButton.textContent = "Verified ✓";
                loginRemotely(customerEmail.value);
            } else {
                codeVerificationLabel.innerHTML = result;
                codeVerificationLabel.style.color = "red";
                codeVerificationLabel.style.opacity = 1;
                codeVerifying = false;
                verifyCodeButton.disabled = false;
                verifyCodeButton.textContent = "Verify code";
            }
        } catch (error) {
            codeVerifying = false;
            verifyCodeButton.disabled = false;
            verifyCodeButton.textContent = "Verify code";
            codeVerificationLabel.innerHTML = "Something went wrong. Try again.";
            codeVerificationLabel.style.color = "red";
            codeVerificationLabel.style.opacity = 1;
        }
    }

    //Logs the user in after verification is complete.
    async function loginRemotely(email) {
        try {
            const response = await fetch("/login-remotely", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({ email, _csrf: csrfToken }),
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = "/profile";
            } else {
                console.error(result.message);
            }
        } catch (error) {
            console.error("Error:", error);
        }
    }
</script>

<footer>
    <%- include('layouts/footer'); -%>
</footer>

</html>
