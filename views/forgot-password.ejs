<!DOCTYPE html>
<html>

<head>
    <%- include('layouts/navbar'); -%>
    <title>Forgot Password | Maple Glow</title>
</head>

<body>
    <div class="fade-in-container" style="max-width: 520px; margin: 0 auto; padding: 3rem var(--page-gutter) 5rem;">

        <!-- Header -->
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--primary-light); color: var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </div>
            <h1 class="login-title" style="margin-bottom: 0.5rem; font-size: 1.8rem;">Forgot Your Password?</h1>
            <p style="color: var(--text-secondary); font-size: 0.98rem; line-height: 1.5; margin: 0;">
                No worries! Enter your registered email address below to receive a 6-digit verification code.
            </p>
        </div>

        <!-- Forgot Password Card Container -->
        <div class="forgot-password-card" style="background: var(--bg-card); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 2.25rem; box-shadow: var(--shadow-sm);">
            
            <!-- Step 1: Email Request -->
            <div class="forgot-step" id="step1" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.75rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border-light);">
                <label class="forgot-step-label" style="font-weight: 700; color: var(--text-primary); font-size: 0.95rem;">
                    Step 1 — Enter Your Email Address
                </label>
                
                <input class="input-box" id="customerEmail" type="email" placeholder="name@example.com" autocomplete="email" style="width: 100%; box-sizing: border-box;">
                
                <span id="emailVerification" class="email-verification" style="font-size: 0.85rem; font-weight: 600; display: none; margin-top: 2px;"></span>
                
                <button id="sendEmailButton" type="button" class="forgot-submit-button" onclick="sendEmail()" style="width: 100%; height: 46px; margin-top: 4px; font-weight: 700; font-size: 0.95rem; border-radius: var(--radius-pill); background-color: var(--primary); color: #ffffff; border: none; cursor: pointer; transition: all var(--transition);">
                    Send Verification Code
                </button>
            </div>

            <!-- Step 2: Code Verification -->
            <div class="forgot-step" id="step2" style="display: flex; flex-direction: column; gap: 0.75rem; opacity: 0.6; pointer-events: none; transition: all var(--transition);">
                <label class="forgot-step-label" style="font-weight: 700; color: var(--text-primary); font-size: 0.95rem;">
                    Step 2 — Enter 6-Digit Verification Code
                </label>

                <input class="input-box" id="code" placeholder="• • • • • •" disabled maxlength="6" style="width: 100%; box-sizing: border-box; text-align: center; font-size: 1.25rem; font-weight: 700; letter-spacing: 8px;">

                <span id="codeVerificationLabel" class="code-verification" style="font-size: 0.85rem; font-weight: 600; display: none; margin-top: 2px;"></span>

                <button id="verifyCodeButton" type="button" class="forgot-submit-button-disabled" onclick="verifyCode()" disabled style="width: 100%; height: 46px; margin-top: 4px; font-weight: 700; font-size: 0.95rem; border-radius: var(--radius-pill); background-color: var(--border-light); color: var(--text-muted); border: none; cursor: not-allowed; transition: all var(--transition);">
                    Verify Code & Log In
                </button>
            </div>

            <!-- Back to Login Link -->
            <div style="text-align: center; margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid var(--border-light);">
                <a href="/login" style="color: var(--text-secondary); text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: color var(--transition);">
                    ← Back to Log In
                </a>
            </div>
        </div>

    </div>

</body>

<script>
    const customerEmail = document.getElementById('customerEmail');
    const codeInput = document.getElementById("code");
    const csrfToken = '<%= csrfToken %>';
    
    let emailSending = false;
    let codeVerifying = false;
    let cooldownTimer = null;
    
    async function sendEmail() {
        if (emailSending) return;
        
        let email = customerEmail.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const verifyCodeButton = document.getElementById("verifyCodeButton");
        const sendEmailButton = document.getElementById("sendEmailButton");
        const emailVerification = document.getElementById("emailVerification");

        if (!emailRegex.test(email)) {
            emailVerification.textContent = "Please enter a valid e-mail address";
            emailVerification.style.color = "#d73a49";
            emailVerification.style.display = "block";
            return;
        }
        
        emailSending = true;
        sendEmailButton.disabled = true;
        sendEmailButton.style.backgroundColor = "var(--border-light)";
        sendEmailButton.style.color = "var(--text-muted)";
        sendEmailButton.style.cursor = "not-allowed";
        sendEmailButton.textContent = "Sending code...";
        
        try {
            const response = await fetch('forgot-password-email', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ email, _csrf: csrfToken }),
            });
            const result = await response.text();
            
            // Enable step 2 container
            const step2 = document.getElementById("step2");
            step2.style.opacity = "1";
            step2.style.pointerEvents = "auto";

            verifyCodeButton.removeAttribute("disabled");
            verifyCodeButton.style.backgroundColor = "var(--primary)";
            verifyCodeButton.style.color = "#ffffff";
            verifyCodeButton.style.cursor = "pointer";

            codeInput.removeAttribute("disabled");
            codeInput.focus();
            customerEmail.setAttribute("disabled", true);
            
            emailVerification.textContent = result || "Verification code sent to your email!";
            emailVerification.style.color = "#1a7f37";
            emailVerification.style.display = "block";

            // Cooldown logic
            let timeLeft = 60;
            sendEmailButton.textContent = `Resend in ${timeLeft}s`;
            
            cooldownTimer = setInterval(() => {
                timeLeft--;
                if (timeLeft <= 0) {
                    clearInterval(cooldownTimer);
                    emailSending = false;
                    sendEmailButton.disabled = false;
                    sendEmailButton.style.backgroundColor = "var(--primary-light)";
                    sendEmailButton.style.color = "var(--primary)";
                    sendEmailButton.style.cursor = "pointer";
                    sendEmailButton.textContent = "Resend Code";
                    customerEmail.removeAttribute("disabled");
                } else {
                    sendEmailButton.textContent = `Resend in ${timeLeft}s`;
                }
            }, 1000);

        } catch (error) {
            emailSending = false;
            sendEmailButton.disabled = false;
            sendEmailButton.style.backgroundColor = "var(--primary)";
            sendEmailButton.style.color = "#ffffff";
            sendEmailButton.style.cursor = "pointer";
            sendEmailButton.textContent = "Send Verification Code";
            emailVerification.textContent = "Something went wrong. Please try again.";
            emailVerification.style.color = "#d73a49";
            emailVerification.style.display = "block";
        }
    }

    async function verifyCode() {
        if (codeVerifying) return;

        const codeValue = codeInput.value.trim();
        const codeVerificationLabel = document.getElementById("codeVerificationLabel");
        const verifyCodeButton = document.getElementById("verifyCodeButton");
        
        if (!codeValue || codeValue.length < 6) {
            codeVerificationLabel.textContent = "Please enter the 6-digit verification code";
            codeVerificationLabel.style.color = "#d73a49";
            codeVerificationLabel.style.display = "block";
            return;
        }

        codeVerifying = true;
        verifyCodeButton.disabled = true;
        verifyCodeButton.textContent = "Verifying code...";

        try {
            const response = await fetch('verify-code', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ codeValue, _csrf: csrfToken }),
            });

            const result = await response.text();

            if (result === "Code verified successfully") {
                codeVerificationLabel.textContent = "✓ Code verified! Logging you in...";
                codeVerificationLabel.style.color = "#1a7f37";
                codeVerificationLabel.style.display = "block";
                verifyCodeButton.textContent = "Verified ✓";
                loginRemotely(customerEmail.value.trim());
            } else {
                codeVerificationLabel.textContent = result || "Invalid verification code";
                codeVerificationLabel.style.color = "#d73a49";
                codeVerificationLabel.style.display = "block";
                codeVerifying = false;
                verifyCodeButton.disabled = false;
                verifyCodeButton.textContent = "Verify Code & Log In";
            }
        } catch (error) {
            codeVerifying = false;
            verifyCodeButton.disabled = false;
            verifyCodeButton.textContent = "Verify Code & Log In";
            codeVerificationLabel.textContent = "Something went wrong. Please try again.";
            codeVerificationLabel.style.color = "#d73a49";
            codeVerificationLabel.style.display = "block";
        }
    }

    async function loginRemotely(email) {
        try {
            const response = await fetch("/login-remotely", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({ email, _csrf: csrfToken }),
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = "/profile";
            } else {
                console.error(result.message);
            }
        } catch (error) {
            console.error("Error:", error);
        }
    }
</script>

<footer>
    <%- include('layouts/footer'); -%>
</footer>

</html>
