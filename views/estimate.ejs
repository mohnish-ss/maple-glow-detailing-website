<!DOCTYPE html>
<html>

<head>
    <%- include('layouts/navbar'); -%>
    <title>Get an AI Estimate | Maple Glow</title>
</head>

<body>
    <div class="fade-in-container" style="max-width: 1120px; margin: 0 auto; padding: 2rem var(--page-gutter) 5rem;">

        <!-- Header -->
        <div class="estimate-header-section" style="text-align: center; margin-bottom: 2.5rem;">
            <h1 class="title" style="margin-bottom: 0.5rem;">AI-Powered Detailing Estimate</h1>
            <p style="color: var(--text-secondary); max-width: 640px; margin: 0 auto; font-size: 1.05rem; line-height: 1.6;">
                Upload a photo of your vehicle below. Our custom AI model will recognize your vehicle type and instantly calculate personalized detailing estimates.
            </p>
        </div>

        <div class="estimate-page-grid">

            <!-- Upload & AI Result Section -->
            <div id="upload-image-container" class="upload-image-container">
                <div id="containerDiv" class="img-upload-div" style="position: relative;">
                    <button id="invisibleButton" onclick="handleButtonClick()" disabled></button>
                    
                    <div id="imgLabel" class="upload-dropzone-content" onclick="document.getElementById('img').click()">
                        <div class="upload-icon-circle">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="17 8 12 3 7 8"></polyline>
                                <line x1="12" y1="3" x2="12" y2="15"></line>
                            </svg>
                        </div>
                        <span class="upload-title">Upload Vehicle Photo</span>
                        <span class="upload-subtitle">Click or select a photo of your car</span>
                    </div>
                    
                    <img id="uploadedImage" class="uploadImg" src="" alt="Uploaded Vehicle Preview">
                </div>

                <div id="label-container" class="hidden-label" style="text-align: center; margin-top: 1.5rem; color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                    Introducing our custom-trained AI model! Our recognition technology scans your vehicle to calculate custom package estimates accurately and effortlessly.
                </div>

                <p style="text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-top: 1.25rem;">
                    *Disclaimer: Prices shown are estimates based on vehicle class. Final pricing may vary based on vehicle condition.
                </p>

                <form action="/action_page.php" style="display: none;">
                    <input type="file" id="img" name="img" accept="image/*" onchange="loadFile(event)" style="display: none;">
                </form>
            </div>

            <!-- Price Estimate Cards Grid -->
            <div id="big-grid" hidden>
                <div class="options-grid-container">

                    <!-- Interior -->
                    <div class="options-grid hidden-option">
                        <div class="estimate-card" onclick="redirectBooking(1)" role="button" tabindex="0">
                            <div class="estimate-card-top">
                                <div class="feature-icon-circle">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                                    </svg>
                                </div>
                                <span id="p1" class="package-price">$100</span>
                            </div>
                            <h3 class="estimate-card-title">Interior</h3>
                            <p class="estimate-card-desc">Elevate your ride's cabin with our deep vacuuming, wipe-downs, and surface restoration.</p>
                            <span class="booking-cta-link">
                                <span>Book Interior Detail</span>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <!-- Exterior -->
                    <div class="options-grid hidden-option">
                        <div class="estimate-card" onclick="redirectBooking(2)" role="button" tabindex="0">
                            <div class="estimate-card-top">
                                <div class="feature-icon-circle">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
                                        <path d="M15 18H9"></path>
                                        <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.24-4.04a1 1 0 0 0-.78-.34H15"></path>
                                        <circle cx="7" cy="18" r="2"></circle>
                                        <circle cx="17" cy="18" r="2"></circle>
                                    </svg>
                                </div>
                                <span id="p2" class="package-price">$100</span>
                            </div>
                            <h3 class="estimate-card-title">Exterior</h3>
                            <p class="estimate-card-desc">Boost your car's street appeal with a meticulous hand wash, paint wax, and exterior shine.</p>
                            <span class="booking-cta-link">
                                <span>Book Exterior Detail</span>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <!-- Full Package -->
                    <div class="options-grid hidden-option">
                        <div class="estimate-card" onclick="redirectBooking(3)" role="button" tabindex="0">
                            <div class="estimate-card-top">
                                <div class="feature-icon-circle">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                    </svg>
                                </div>
                                <span id="p3" class="package-price">$200</span>
                            </div>
                            <h3 class="estimate-card-title">Full Package</h3>
                            <p class="estimate-card-desc">Give your vehicle a total inside-and-out refresh combining complete interior & exterior care.</p>
                            <span class="booking-cta-link">
                                <span>Book Full Package</span>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>

                    <!-- Headlight Polish -->
                    <div class="options-grid hidden-option">
                        <div class="estimate-card" onclick="redirectBooking(4)" role="button" tabindex="0">
                            <div class="estimate-card-top">
                                <div class="feature-icon-circle">
                                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="5"></circle>
                                        <line x1="12" y1="1" x2="12" y2="3"></line>
                                        <line x1="12" y1="21" x2="12" y2="23"></line>
                                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                                        <line x1="1" y1="12" x2="3" y2="12"></line>
                                        <line x1="21" y1="12" x2="23" y2="12"></line>
                                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                                    </svg>
                                </div>
                                <span id="p4" class="package-price">$50</span>
                            </div>
                            <h3 class="estimate-card-title">Headlight Polish</h3>
                            <p class="estimate-card-desc">Clear up oxidation and yellowing for restored nighttime driving visibility and razor-sharp looks.</p>
                            <span class="booking-cta-link">
                                <span>Book Headlight Polish</span>
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </span>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</body>

<!-- Script imports for teachable machine -->
<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@latest/dist/tf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@latest/dist/teachablemachine-image.min.js"></script>

<script>
    const URLTeachable = "https://teachablemachine.withgoogle.com/models/dy0VvIqtW/";
    let modelPromise = null;
    let model = null;
    let maxPredictions = 0;

    // Preload & warm up model on DOM load to eliminate lag when user selects an image
    document.addEventListener("DOMContentLoaded", () => {
        preloadModel();
    });

    async function preloadModel() {
        if (!modelPromise) {
            const modelURL = URLTeachable + "model.json";
            const metadataURL = URLTeachable + "metadata.json";
            modelPromise = tmImage.load(modelURL, metadataURL).then(async (loadedModel) => {
                model = loadedModel;
                maxPredictions = loadedModel.getTotalClasses();

                // Warmup TensorFlow shaders & GPU pipeline on background canvas
                try {
                    if (window.tf) {
                        await tf.ready();
                    }
                    const dummyCanvas = document.createElement('canvas');
                    dummyCanvas.width = 224;
                    dummyCanvas.height = 224;
                    await loadedModel.predict(dummyCanvas);
                } catch (e) {
                    // Silently ignore warmup errors
                }

                return loadedModel;
            }).catch(err => {
                console.error("Failed to preload AI model:", err);
            });
        }
        return modelPromise;
    }

    function redirectBooking(buttonId) {
        if ("<%= username %>") {
            window.location.href = '/booking?selectedButton=' + buttonId;
        } else {
            window.location.href = '/login';
        }
    }

    function moveUploadImage() {
        const grid = document.querySelector('.estimate-page-grid');
        if (grid) {
            grid.classList.add('has-estimate');
        }
    }

    function showLabel() {
        const label = document.getElementById("label-container");
        label.classList.add("show-label");
    }

    function hideLabel() {
        const label = document.getElementById("label-container");
        label.classList.remove("show-label");
    }

    var loadFile = async function (event) {
        const file = event.target.files && event.target.files[0];
        if (!file) return;

        var image = document.getElementById("uploadedImage");
        document.getElementById("invisibleButton").style.cursor = "pointer";
        document.getElementById("imgLabel").style.display = "none";

        const labelContainer = document.getElementById("label-container");
        labelContainer.style.fontSize = "18px";
        labelContainer.style.fontWeight = "600";
        labelContainer.innerHTML = "Analyzing vehicle with AI...";
        showLabel();

        // Wait for image decoding before running prediction
        await new Promise((resolve) => {
            image.onload = resolve;
            image.src = URL.createObjectURL(file);
            image.style.display = "block";
        });

        moveUploadImage();
        document.getElementById("big-grid").removeAttribute('hidden');

        // Yield to browser rendering loop and wait for the 0.5s CSS transition to finish so UI animation paints smoothly before heavy AI prediction
        await new Promise(r => requestAnimationFrame(() => setTimeout(r, 600)));

        if (!model) {
            await preloadModel();
        }

        if (model) {
            const prediction = await model.predict(image);
            let highest = -1;
            let vtype = "";
            for (let i = 0; i < maxPredictions; i++) {
                const prob = parseFloat(prediction[i].probability.toFixed(2));
                if (prob > highest) {
                    highest = prob;
                    vtype = prediction[i].className;
                }
            }
            updatePrice(vtype);
            updateOptions();
            labelContainer.style.fontSize = "24px";
            labelContainer.style.fontWeight = "700";
            labelContainer.style.color = "var(--text-primary)";
            labelContainer.innerHTML = `Your vehicle is classified as a <span style="color: var(--primary); font-weight: 800;">${vtype}</span>`;
        }
    };

    var handleButtonClick = function () {
        document.getElementById("img").click();
        hideOptions();
        hideLabel();
    };

    function hideOptions() {
        const options = document.querySelectorAll(".options-grid");
        options.forEach(option => {
            option.classList.remove('show-option');
        });
    }

    function updateOptions() {
        const options = document.querySelectorAll(".options-grid");
        options.forEach(option => {
            option.classList.add('show-option');
        });
    }

    function updatePrice(vtype) {
        let factor = 1;
        if (vtype == "Sedan") factor = 1;
        else if (vtype == "Truck") factor = 2;
        else if (vtype == "SUV") factor = 1.5;
        else factor = 1.75;

        document.getElementById("p1").innerHTML = "$" + (factor * 100);
        document.getElementById("p2").innerHTML = "$" + (factor * 100);
        document.getElementById("p3").innerHTML = "$" + (factor * 200);
        document.getElementById("p4").innerHTML = "$" + (factor * 50);
    }
</script>

<footer>
    <%- include('layouts/footer'); -%>
</footer>

</html>