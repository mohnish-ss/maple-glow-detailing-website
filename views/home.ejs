<!DOCTYPE html>
<head>
    <meta name="google-site-verification" content="u2Y4CkwJm1hfKDbmA4Df4JVMlzWVWQB2uaV7kCMSwcg" />
    <%- include('layouts/navbar'); -%>
        <title>Homepage</title>
</head>

<!-- Image compairason slider made by "sneas", implemented from https://github.com/sneas/img-comparison-slider. -->
<script defer src="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/index.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/styles.css" />

<body>

    <div class="fade-in-container">

        <div class="homepage-background-image">
            <div class="hero-content">
                <h1 class="homepage-title">Maple Glow Detailing</h1>
                <p class="hero-subtitle">
                    Mobile car detailing for cleaner cabins, brighter paint, and headlights that look sharp again.
                </p>
                <div class="hero-action">
                    <% if (username) { %>
                        <a href="/booking"><button class="book-button" type="button">Book now</button></a>
                    <% } else { %>
                        <a href="/login"><button class="book-button" type="button">Book now</button></a>
                    <% } %>
                </div>
            </div>
        </div>

        <section class="service-strip" aria-label="Maple Glow service highlights">
            <div class="service-stat">
                <span>01</span>
                <strong>Interior refresh</strong>
                <p>Vacuuming, wipe-downs, and careful cabin cleaning.</p>
            </div>
            <div class="service-stat">
                <span>02</span>
                <strong>Exterior care</strong>
                <p>Wash, shine, and finish work for a cleaner vehicle.</p>
            </div>
            <div class="service-stat">
                <span>03</span>
                <strong>Simple booking</strong>
                <p>Choose your package, date, and time in one flow.</p>
            </div>
        </section>

        <div class="slider-section">
            <h1 class="slider-title title">Before & After</h1>
            
            <div class="homepage-comparison-slider">
                <img-comparison-slider class="slider-color slider-focus" value="72">
                    <img slot="first" class="slider-image" src="images/headlight_before.png">
                    <img slot="second" class="slider-image" src="images/headlight_after.png">
                    <svg slot="handle" xmlns="http://www.w3.org/2000/svg" width="100" viewBox="-8 -3 16 6">
                        <path stroke="#0071e3" d="M -5 -2 L -7 0 L -5 2 M -5 -2 L -5 2 M 5 -2 L 7 0 L 5 2 M 5 -2 L 5 2"
                            stroke-width="1.5" fill="none" vector-effect="non-scaling-stroke"></path>
                    </svg>
                </img-comparison-slider>

                <img-comparison-slider class="slider-color slider-focus" value="52.5">
                    <img slot="first" class="slider-image" src="images/wheel-before.png">
                    <img slot="second" class="slider-image" src="images/wheel-after.png">
                    <svg slot="handle" xmlns="http://www.w3.org/2000/svg" width="100" viewBox="-8 -3 16 6">
                        <path stroke="#0071e3" d="M -5 -2 L -7 0 L -5 2 M -5 -2 L -5 2 M 5 -2 L 7 0 L 5 2 M 5 -2 L 5 2"
                            stroke-width="1.5" fill="none" vector-effect="non-scaling-stroke"></path>
                    </svg>
                </img-comparison-slider>
            </div>
        </div>

    </div>

</body>

<style>
    /* "@media" is used to ensure the elements on the page resize properly within the user's screen size. */
    @media (max-width: 1294px) {
        .homepage-comparison-slider {
            flex-direction: column;
            align-items: center;
        }
    }
</style>

<footer>
    <%- include('layouts/footer'); -%>
</footer>

</html>
